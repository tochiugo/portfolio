{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/((?!api/|evidence/|images/|assets/|resume.html|og-preview|robots|sitemap|favicon|status.json).*)", "destination": "/index.html" }
  ]
}
